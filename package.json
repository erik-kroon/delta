{
  "name": "delta",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "catalog": {
      "typescript": "^6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/three": "^0.184.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
